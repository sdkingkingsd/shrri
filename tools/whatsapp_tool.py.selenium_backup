def send_media(contact: str, file_path: str, caption: str = "") -> str:
    """Send an image or file to a WhatsApp contact."""
    try:
        import os
        from selenium import webdriver
        from selenium.webdriver.chrome.service import Service
        from selenium.webdriver.chrome.options import Options
        from selenium.webdriver.common.by import By
        from selenium.webdriver.support.ui import WebDriverWait
        from selenium.webdriver.support import expected_conditions as EC
        import time

        file_path = os.path.expanduser(file_path)
        if not os.path.exists(file_path):
            return f"GAP: file not found - {file_path}"

        options = Options()
        options.add_argument("--user-data-dir=" + CHROME_PROFILE)
        options.add_argument("--no-sandbox")
        options.add_argument("--disable-dev-shm-usage")
        options.add_argument("--headless=new")
        options.add_argument("--window-size=1920,1080")

        driver = webdriver.Chrome(service=Service(CHROMEDRIVER), options=options)
        wait = WebDriverWait(driver, 30)
        driver.get("https://web.whatsapp.com")
        wait.until(EC.presence_of_element_located((By.XPATH, "//*[@aria-label='Chat list']")))
        time.sleep(4)

        search = driver.find_element(By.XPATH, "//*[@aria-label='Search or start a new chat']")
        search.click()
        search.send_keys(contact)
        time.sleep(2)
        chats = driver.find_elements(By.XPATH, "//*[@aria-label='Chat list']//*[@tabindex='-1']")
        if not chats:
            driver.quit()
            return f"GAP: contact not found: {contact}"
        chats[0].click()
        time.sleep(3)

        attach = wait.until(EC.element_to_be_clickable(
            (By.XPATH, "//*[@aria-label='Attach' or @title='Attach']")
        ))
        attach.click()
        time.sleep(1)

        file_input = driver.find_element(By.XPATH, "//input[@accept and @type='file']")
        file_input.send_keys(file_path)
        time.sleep(3)

        if caption:
            try:
                cap_box = driver.find_element(By.XPATH, "//div[@contenteditable='true' and @data-tab='10']")
                cap_box.send_keys(caption)
                time.sleep(1)
            except Exception:
                pass

        send_btn = wait.until(EC.element_to_be_clickable(
            (By.XPATH, "//button[@aria-label='Send']")
        ))
        send_btn.click()
        time.sleep(3)
        driver.quit()
        fname = os.path.basename(file_path)
        return f"Sent {fname} to {contact}"
    except Exception as e:
        try: driver.quit()
        except: pass
        return f"GAP: media send failed - {e}"


