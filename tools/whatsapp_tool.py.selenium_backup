def forward_message(from_contact: str, to_contact: str) -> str:
    """Forward the latest message from one contact to another."""
    try:
        from selenium import webdriver
        from selenium.webdriver.chrome.service import Service
        from selenium.webdriver.chrome.options import Options
        from selenium.webdriver.common.by import By
        from selenium.webdriver.support.ui import WebDriverWait
        from selenium.webdriver.support import expected_conditions as EC
        from selenium.webdriver.common.action_chains import ActionChains
        import time

        options = Options()
        options.add_argument("--user-data-dir=" + CHROME_PROFILE)
        options.add_argument("--no-sandbox")
        options.add_argument("--disable-dev-shm-usage")
        options.add_argument("--headless=new")
        options.add_argument("--window-size=1920,1080")

        driver = webdriver.Chrome(service=Service(CHROMEDRIVER), options=options)
        wait = WebDriverWait(driver, 30)
        driver.get("https://web.whatsapp.com")
        wait.until(EC.presence_of_element_located((By.XPATH, "//*[@aria-label='Chat list']")))
        time.sleep(4)

        search = driver.find_element(By.XPATH, "//*[@aria-label='Search or start a new chat']")
        search.click()
        search.send_keys(from_contact)
        time.sleep(2)
        chats = driver.find_elements(By.XPATH, "//*[@aria-label='Chat list']//*[@tabindex='-1']")
        if not chats:
            driver.quit()
            return f"GAP: contact not found: {from_contact}"
        chats[0].click()
        time.sleep(3)

        msgs = driver.find_elements(By.XPATH, "//div[contains(@class,'message-in') or contains(@class,'message-out')]")
        if not msgs:
            driver.quit()
            return "GAP: no messages found."
        last = msgs[-1]
        ActionChains(driver).move_to_element(last).perform()
        time.sleep(1)

        ActionChains(driver).context_click(last).perform()
        time.sleep(1)
        fwd_btn = driver.find_element(By.XPATH, "//*[text()='Forward message' or text()='Forward']")
        fwd_btn.click()
        time.sleep(2)

        fwd_search = driver.find_element(By.XPATH, "//input[@placeholder='Search...' or @placeholder='Search']")
        fwd_search.send_keys(to_contact)
        time.sleep(2)
        results = driver.find_elements(By.XPATH, "//span[@title]")
        for r in results:
            if to_contact.lower() in (r.get_attribute("title") or "").lower():
                r.click()
                break
        time.sleep(1)

        send_btn = driver.find_element(By.XPATH, "//button[@aria-label='Send' or contains(@class,'send')]")
        send_btn.click()
        time.sleep(2)
        driver.quit()
        return f"Forwarded message from {from_contact} to {to_contact}"
    except Exception as e:
        try: driver.quit()
        except: pass
        return f"GAP: forward failed - {e}"
